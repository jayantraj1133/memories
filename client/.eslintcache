ecatedRules":"32"},"D:\\pro\\react\\2\\memories-example\\client\\src\\index.js",[],["60","61"],"D:\\pro\\react\\2\\memories-example\\client\\src\\App.js",[],"D:\\pro\\react\\2\\memories-example\\client\\src\\components\\Posts\\Posts.js",[],"D:\\pro\\react\\2\\memories-example\\client\\src\\components\\Form\\Form.js",[],"D:\\pro\\react\\2\\memories-example\\client\\src\\components\\Posts\\Post\\Post.js",[],"D:\\pro\\react\\2\\memories-example\\client\\src\\style.js",[],"D:\\pro\\react\\2\\memories-example\\client\\src\\components\\Form\\styles.js",[],"D:\\pro\\react\\2\\memories-example\\client\\src\\components\\Posts\\Post\\styles.js",[],"D:\\pro\\react\\2\\memories-example\\client\\src\\components\\Posts\\styles.js",[],"D:\\pro\\react\\2\\memories-example\\client\\src\\reducers\\index.js",[],"D:\\pro\\react\\2\\memories-example\\client\\src\\reducers\\posts.js",["62"],"import {CREATE,UPDATE,DELETE,FETCH_ALL}  from '../constants/actionTypes';\r\n\r\n\r\nexport default (posts=[],action)=>{\r\n    switch(action.type){\r\n\r\n        case DELETE:\r\n            return posts.filter((post) => post._id !== action.payload);\r\n        case UPDATE:\r\n            return posts.map((post)=>post._id ===action.payload._id ? action.payload : post)  //action.payload is updated post\r\n    \r\n        case FETCH_ALL:\r\n            return action.payload;\r\n        \r\n        case CREATE:\r\n            return [...posts,action.payload];\r\n        \r\n        default:\r\n            return posts;   \r\n    }\r\n}","D:\\pro\\react\\2\\memories-example\\client\\src\\actions\\posts.js",[],"D:\\pro\\react\\2\\memories-example\\client\\src\\api\\index.js",[],"D:\\pro\\react\\2\\memories-example\\client\\src\\constants\\actionTypes.js",[],{"ruleId":"63","replacedBy":"64"},{"ruleId":"65","replacedBy":"66"},{"ruleId":"67","severity":1,"message":"68","line":4,"column":1,"nodeType":"69","endLine":21,"endColumn":2},"no-native-reassign",["70"],"no-negated-in-lhs",["71"],"import/no-anonymous-